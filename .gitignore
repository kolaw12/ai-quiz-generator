# ==============================
# SECRETS & ENVIRONMENT VARIABLES (NEVER PUSH THESE)
# ==============================
.env
.env.*
!.env.example
!.env.local.example

# ==============================
# FRONTEND (Next.js & Node)
# ==============================
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/dist/
frontend/.vercel/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
frontend/.eslintcache

# ==============================
# BACKEND (FastAPI & Python)
# ==============================
backend/venv/
backend/env/
backend/__pycache__/
backend/**/*.pyc
backend/**/*.pyo
backend/**/*.pyd
backend/.pytest_cache/
backend/logs/

